{
	acme_ca https://acme.zerossl.com/v2/DV90
	email {$ACME_EMAIL:admin@attestfor.me}
}

{$DOMAIN:attestfor.me} {
	encode zstd gzip

	handle /u/* {
		uri strip_prefix /u
		reverse_proxy umami:3000
	}

	# Hashed asset files are content-addressed — safe to cache for 1 year
	handle /assets/* {
		header Cache-Control "public, max-age=31536000, immutable"
		reverse_proxy app:3000
	}

	reverse_proxy app:3000
}

analytics.{$DOMAIN:attestfor.me} {
	reverse_proxy umami:3000
}

testfor.me, at.testfor.me {
	redir https://{$DOMAIN:attestfor.me}{uri} permanent
}

manoo.dev {
	redir https://{$DOMAIN:attestfor.me}/manoo.dev 301
}
