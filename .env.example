# ── Local development ───────────────────────────────────────────────
# Base URL for the app (only needed for local dev, e.g. dev tunnels)
APP_URL=https://your-tunnel.devtunnels.ms

# Cookie secret for session security
COOKIE_SECRET=change-this-in-production

# Redis URL (optional locally - uses in-memory storage if not set)
# REDIS_URL=redis://localhost:6379

# ── Production (docker-compose) ────────────────────────────────────
# Only DOMAIN and COOKIE_SECRET are needed. docker-compose.yml
# derives APP_URL, REDIS_URL, etc. automatically.
#
# DOMAIN=attestfor.me
# COOKIE_SECRET=<generate with: openssl rand -hex 32>
