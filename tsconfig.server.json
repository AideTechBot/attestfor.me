{
  "extends": "./tsconfig.node.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": false,
    "declaration": true
  },
  "include": ["server/**/*", "types/**/*"],
  "exclude": ["node_modules", "dist", "src"]
}
