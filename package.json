{
  "name": "attestfor.me",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "ts-node-esm server/dev-server.ts",
    "dev:prod-server": "ts-node-esm server/index.ts",
    "build:client": "vite build --outDir dist/client",
    "build:server:ts": "tsc -p tsconfig.server.json",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server && pnpm run build:server:ts",
    "build": "tsc -b && pnpm run build:client && pnpm run build:server",
    "start": "node dist/server/index.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint"
  },
  "dependencies": {
    "@fastify/express": "^4.0.4",
    "@fastify/static": "^9.0.0",
    "fastify": "^5.7.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
