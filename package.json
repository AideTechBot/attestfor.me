{
  "name": "attestfor.me",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx server/dev-server.ts",
    "dev:prod-server": "tsx server/index.ts",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server && vite build --ssr server/index.ts --outDir dist/server --emptyOutDir false",
    "build": "tsc -b && pnpm run build:client && pnpm run build:server",
    "start": "node dist/server/index.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "update-oauth-url": "tsx scripts/update-oauth-url.ts",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint && ! grep -q devtunnels public/oauth/client-metadata.json || (echo 'Error: dev tunnel URL in client-metadata.json' && exit 1)"
  },
  "pnpm": {
    "patchedDependencies": {
      "@keytrace/runner": "patches/@keytrace__runner.patch"
    }
  },
  "dependencies": {
    "@atcute/atproto": "^3.1.10",
    "@atcute/client": "^4.2.1",
    "@atcute/identity-resolver": "^1.2.2",
    "@atcute/identity-resolver-node": "^1.0.3",
    "@atcute/lexicons": "^1.2.9",
    "@atcute/oauth-node-client": "^1.1.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/express": "^4.0.4",
    "@fastify/static": "^9.0.0",
    "@keytrace/lexicon": "0.0.11",
    "@keytrace/runner": "0.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.4",
    "fastify": "^5.7.2",
    "ioredis": "^5.9.2",
    "lucide-react": "^0.563.0",
    "openpgp": "^6.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
